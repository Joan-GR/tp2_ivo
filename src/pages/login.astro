---
import { createSupabaseClient } from "../lib/supabase";

const supabase = createSupabaseClient(Astro.cookies);

const { data: { user } } = await supabase.auth.getUser();
if (user) return Astro.redirect("/");

let errorMsg = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = form.get("email")?.toString() ?? "";
  const password = form.get("password")?.toString() ?? "";

  const { error } = await supabase.auth.signInWithPassword({ email, password });

  if (error) {
    errorMsg = "Email o contraseña incorrectos";
  } else {
    return Astro.redirect("/");
  }
}
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar sesión · Lista de Compras</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800&family=Poppins:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --verde: #2d6a4f; --verde-cl: #52b788; --fondo: #f8f5f0;
      --papel: #ffffff; --texto: #1b1b1b; --muted: #7a7a7a;
      --borde: #e0dbd3; --rojo: #c0392b; --sombra: 0 2px 12px rgba(0,0,0,.08);
    }
    body {
      font-family: 'Poppins', sans-serif;
      background: var(--fondo);
      color: var(--texto);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    header {
      background: var(--verde);
      color: #fff;
      padding: 1.2rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 8px rgba(0,0,0,.18);
    }
    header h1 {
      font-family: 'Nunito', sans-serif;
      font-size: 1.7rem;
      letter-spacing: .02em;
    }
    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2.5rem 1.2rem;
    }
    .card {
      background: var(--papel);
      border-radius: 12px;
      box-shadow: var(--sombra);
      padding: 2.2rem 2rem;
      width: 100%;
      max-width: 420px;
    }
    .card h2 {
      font-family: 'Nunito', sans-serif;
      font-size: 1.4rem;
      color: var(--verde);
      margin-bottom: 1.6rem;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.4rem;
    }
    label {
      display: flex;
      flex-direction: column;
      gap: .3rem;
      font-size: .82rem;
      color: var(--muted);
      font-weight: 500;
    }
    input[type="email"],
    input[type="password"] {
      padding: .6rem .8rem;
      border: 1.5px solid var(--borde);
      border-radius: 8px;
      font-size: .95rem;
      font-family: inherit;
      background: var(--fondo);
      transition: border-color .2s;
      width: 100%;
    }
    input:focus { outline: none; border-color: var(--verde-cl); }
    .btn-submit {
      width: 100%;
      background: var(--verde);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: .75rem;
      font-size: 1rem;
      font-family: inherit;
      font-weight: 500;
      cursor: pointer;
      transition: background .2s, transform .1s;
    }
    .btn-submit:hover { background: #235c40; }
    .btn-submit:active { transform: scale(.98); }
    .error {
      color: var(--rojo);
      font-size: .85rem;
      margin-bottom: 1rem;
      padding: .6rem .8rem;
      background: #fdf0ef;
      border-radius: 7px;
      border: 1px solid #f5c6c2;
    }
    .footer-link {
      text-align: center;
      margin-top: 1.2rem;
      font-size: .88rem;
      color: var(--muted);
    }
    .footer-link a {
      color: var(--verde);
      font-weight: 500;
      text-decoration: none;
    }
    .footer-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <header>
    <h1>Lista de Compras</h1>
  </header>
  <main>
    <div class="card">
      <h2>Iniciar sesión</h2>
      {errorMsg && <p class="error">{errorMsg}</p>}
      <form method="POST">
        <div class="form-group">
          <label>
            Email
            <input type="email" name="email" placeholder="tu@email.com" required />
          </label>
          <label>
            Contraseña
            <input type="password" name="password" placeholder="Tu contraseña" required />
          </label>
        </div>
        <button type="submit" class="btn-submit">Ingresar</button>
      </form>
      <p class="footer-link">¿No tenés cuenta? <a href="/register">Registrate</a></p>
    </div>
  </main>
</body>
</html>
